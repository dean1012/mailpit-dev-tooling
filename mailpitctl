#!/usr/bin/env bash
set -euo pipefail

# mailpitctl - Manage a local Mailpit Docker Compose service.

SERVICE_NAME="mailpit"
CONTAINER_NAME="mailpit"
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="${SCRIPT_DIR}/config.env"

MAILPIT_WEB_BIND="${MAILPIT_WEB_BIND:-127.0.0.1}"
MAILPIT_WEB_PORT="${MAILPIT_WEB_PORT:-8025}"
MAILPIT_SMTP_BIND="${MAILPIT_SMTP_BIND:-127.0.0.1}"
MAILPIT_SMTP_PORT="${MAILPIT_SMTP_PORT:-1025}"
MAILPIT_WAIT_TIMEOUT="${MAILPIT_WAIT_TIMEOUT:-30}"
MAILPIT_IMAGE="${MAILPIT_IMAGE:-axllent/mailpit:v1.30.1@sha256:3bd7c2f2696deb35a4780d152b404dceec99cb041b942c0877b3b22384714f85}"

GREEN='\033[0;32m'
YELLOW='\033[0;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
NC='\033[0m'

###############################################################################
# Functions
#
# Utility, validation, status, and container lifecycle management functions.
###############################################################################

usage() {
  cat << EOF
Usage: $0 [--help] <command>

Options:
  -h, --help    Display usage information

Commands:
  start, up     Create the $CONTAINER_NAME container if needed, then start it
  update        Pull the configured image, then recreate and start the $CONTAINER_NAME container
  stop, down    Stop the $CONTAINER_NAME container
  restart       Restart the $CONTAINER_NAME container
  status        Show $CONTAINER_NAME container status
  logs [options]
                Display container logs, passing options to docker compose logs
  destroy       Stop and remove the $CONTAINER_NAME container
EOF
}

display_success() {
  printf '%b%s%b\n' "$GREEN" "$1" "$NC"
}

display_warning() {
  printf '%bWarning: %s%b\n' "$YELLOW" "$1" "$NC" >&2
}

display_error() {
  local message="$1"
  local hint="${2:-}"

  if [[ -n "$hint" ]]; then
    printf '%bError: %s: %s %b%s%b\n' "$RED" "$message" "$CONTAINER_NAME" "$BLUE" "$hint" "$NC" >&2
  else
    printf '%bError: %s: %s%b\n' "$RED" "$message" "$CONTAINER_NAME" "$NC" >&2
  fi
}

error_occurred() {
  display_error "failed to $1 container"
  exit 1
}

require_docker() {
  if ! command -v docker > /dev/null 2>&1; then
    printf '%bError: Docker CLI is not installed%b\n' "$RED" "$NC" >&2
    exit 1
  fi

  if ! docker info > /dev/null 2>&1; then
    printf '%bError: unable to communicate with the Docker daemon%b\n' "$RED" "$NC" >&2
    exit 1
  fi

  if ! docker compose version > /dev/null 2>&1; then
    printf '%bError: Docker Compose is not installed%b\n' "$RED" "$NC" >&2
    exit 1
  fi
}

validate_usage() {
  if [[ "$#" -gt 1 ]]; then
    printf '%bError: too many arguments for command: %s%b\n\n' "$RED" "$1" "$NC" >&2
    usage
    exit 1
  fi
}

load_config() {
  local line key value line_number

  [[ -f "$CONFIG_FILE" ]] || return 0

  # Parse config.env as data instead of shell code. Only the documented keys are
  # accepted; values are assigned literally so command substitutions never run.
  line_number=0
  while IFS= read -r line || [[ -n "$line" ]]; do
    line_number=$((line_number + 1))
    line="${line%$'\r'}"

    if [[ -z "$line" || "$line" == \#* ]]; then
      continue
    fi

    if [[ "$line" != *=* ]]; then
      printf '%bError: invalid config.env line %s: expected KEY=VALUE%b\n' \
        "$RED" "$line_number" "$NC" >&2
      exit 1
    fi

    key="${line%%=*}"
    value="${line#*=}"

    case "$key" in
      MAILPIT_IMAGE | MAILPIT_WEB_BIND | MAILPIT_WEB_PORT | MAILPIT_SMTP_BIND | MAILPIT_SMTP_PORT | MAILPIT_WAIT_TIMEOUT)
        printf -v "$key" '%s' "$value"
        ;;
      *)
        printf '%bError: invalid config.env line %s: unsupported key: %s%b\n' \
          "$RED" "$line_number" "$key" "$NC" >&2
        exit 1
        ;;
    esac
  done < "$CONFIG_FILE"
}

compose_command() {
  local compose_args=(
    --project-directory "$SCRIPT_DIR"
    --file "${SCRIPT_DIR}/compose.yml"
  )

  if [[ -f "$CONFIG_FILE" ]]; then
    compose_args+=(--env-file "$CONFIG_FILE")
  fi

  docker compose "${compose_args[@]}" "$@"
}

compose_container_exists() {
  [[ -n "$(compose_command ps --all --quiet "$SERVICE_NAME")" ]]
}

container_exists() {
  docker container inspect "$CONTAINER_NAME" > /dev/null 2>&1
}

container_running() {
  [[ -n "$(compose_command ps --status running --quiet "$SERVICE_NAME")" ]]
}

container_healthy() {
  # Docker Compose emits one JSON object per service; Mailpit's healthcheck is
  # the source of truth for whether the local SMTP/UI endpoints are ready.
  compose_command ps --format json "$SERVICE_NAME" | grep -q '"Health":"healthy"'
}

wait_for_container() {
  compose_command up --detach --wait --wait-timeout "$MAILPIT_WAIT_TIMEOUT" "$SERVICE_NAME" \
    || error_occurred wait
}

display_missing_container_error() {
  if container_exists; then
    # A fixed container name is intentional, but a hand-created container with
    # that name cannot be managed safely by this Compose project.
    display_error "container is not managed by Docker Compose" \
      "[Remove it with: docker rm -f $CONTAINER_NAME]"
  else
    display_error "container does not exist" "[Try running: $0 start]"
  fi
}

container_status() {
  if ! compose_container_exists; then
    display_missing_container_error
    return 1
  fi

  if container_running; then
    display_success "Container is running"
    if container_healthy; then
      display_success "Container is healthy"
    else
      display_warning "container is running but not healthy"
    fi
  else
    printf '%bContainer is stopped%b\n' "$RED" "$NC"
  fi
  printf '\n'

  compose_command ps --all "$SERVICE_NAME"
}

start_container() {
  if container_running; then
    if container_healthy; then
      display_success "Container is already running"
    else
      display_warning "container is already running but not healthy; waiting for health..."
      wait_for_container
      display_success "Container is running and healthy"
    fi
    return
  fi

  if ! compose_container_exists && container_exists; then
    display_missing_container_error
    return 1
  fi

  wait_for_container

  display_success "Started container: $CONTAINER_NAME"
  printf '\n'
  display_success "Mailpit UI: http://${MAILPIT_WEB_BIND}:${MAILPIT_WEB_PORT}"
  display_success "SMTP: ${MAILPIT_SMTP_BIND}:${MAILPIT_SMTP_PORT}"
}

update_container() {
  if ! compose_container_exists && container_exists; then
    display_missing_container_error
    return 1
  fi

  compose_command pull "$SERVICE_NAME" || error_occurred update
  compose_command up --detach --force-recreate --wait --wait-timeout "$MAILPIT_WAIT_TIMEOUT" "$SERVICE_NAME" \
    || error_occurred update

  display_success "Updated container: $CONTAINER_NAME"
}

stop_container() {
  if ! compose_container_exists; then
    display_missing_container_error
    return 1
  fi

  if ! container_running; then
    display_success "Container is not running"
    return
  fi

  compose_command stop "$SERVICE_NAME" > /dev/null || error_occurred stop

  display_success "Stopped container"
}

restart_container() {
  if ! compose_container_exists; then
    display_missing_container_error
    return 1
  fi

  if ! container_running; then
    display_warning "container is stopped; starting it now..."
    compose_command start "$SERVICE_NAME" > /dev/null || error_occurred restart
  else
    compose_command restart "$SERVICE_NAME" > /dev/null || error_occurred restart
  fi
  wait_for_container

  display_success "Restarted container: $CONTAINER_NAME"
}

destroy_container() {
  if ! compose_container_exists; then
    display_missing_container_error
    return 1
  fi

  compose_command down > /dev/null || error_occurred destroy

  if compose_container_exists; then
    error_occurred destroy
  fi

  display_success "Destroyed container"
}

logs_container() {
  require_docker

  if ! compose_container_exists; then
    display_missing_container_error
    return 1
  fi

  compose_command logs "$@" "$SERVICE_NAME" || error_occurred logs
}

###############################################################################
# Global Help Handling
#
# Detect and process help flags regardless of argument position so that:
#
#   ./mailpitctl --help
#   ./mailpitctl up --help
#   ./mailpitctl logs --help
#
# all display usage information and exit cleanly before command execution.
###############################################################################
for arg in "$@"; do
  case "$arg" in
    -h | --help)
      usage
      exit 0
      ;;
  esac
done

load_config
export MAILPIT_IMAGE MAILPIT_WEB_BIND MAILPIT_WEB_PORT MAILPIT_SMTP_BIND MAILPIT_SMTP_PORT MAILPIT_WAIT_TIMEOUT

###############################################################################
# Main Program
#
# Parse command-line arguments and dispatch requested container operations.
###############################################################################

case "${1:-}" in
  start | up)
    validate_usage "$@"
    require_docker
    start_container
    ;;
  update)
    validate_usage "$@"
    require_docker
    update_container
    ;;
  stop | down)
    validate_usage "$@"
    require_docker
    stop_container
    ;;
  restart)
    validate_usage "$@"
    require_docker
    restart_container
    ;;
  status)
    validate_usage "$@"
    require_docker
    container_status
    ;;
  logs)
    shift || true
    logs_container "$@"
    ;;
  destroy)
    validate_usage "$@"
    require_docker
    destroy_container
    ;;
  *)
    if [ $# -gt 0 ]; then
      printf '%bError: invalid command: %s%b\n\n' "$RED" "${1:-}" "$NC" >&2
    fi

    usage
    exit 1
    ;;
esac
