# Copy this file to config.env to customize your local Mailpit instance.
#
# The values below are the built-in defaults. You can leave config.env absent
# and the script/Compose file will still use these same settings.

# Local interface for the Mailpit web UI. Keep 127.0.0.1 for local-only access.
MAILPIT_WEB_BIND=127.0.0.1

# Local port for the Mailpit web UI.
MAILPIT_WEB_PORT=8025

# Local interface for the Mailpit SMTP listener. Keep 127.0.0.1 for local-only
# access unless another machine must send mail to this development environment.
MAILPIT_SMTP_BIND=127.0.0.1

# Local port for the Mailpit SMTP listener.
MAILPIT_SMTP_PORT=1025

# Seconds to wait for Docker Compose health checks during start/update/restart.
MAILPIT_WAIT_TIMEOUT=30
